# =========================================
# MugneeKH - Clean Canonical .htaccess
# CyberPanel / Apache / LiteSpeed friendly
# =========================================

<IfModule mod_alias.c>
  # Enforce legacy catalog URLs to canonical product URLs.
  RedirectMatch 301 ^/products/catalog/(.+)/?$ /products/$1/
  RedirectMatch 301 ^/km/products/catalog/(.+)/?$ /km/products/$1/
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # 0) Allow well-known (SSL, etc.)
  RewriteRule ^\.well-known/ - [L]

  # 1) Single-hop canonical: force https + non-www
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.mugneekh\.com$ [NC]
  RewriteRule ^ https://mugneekh.com%{REQUEST_URI} [R=301,L]

  # 2) Remove duplicate slashes (only when requested URL contains //)
  RewriteCond %{THE_REQUEST} \s/+(.+?)//+ [NC]
  RewriteRule ^ %1 [R=301,L]

  # 3) Enforce trailing slash for “pages” (skip real files/folders)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]{1,5}$ [NC]
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^ %{REQUEST_URI}/ [R=301,L]

  # 4) Next.js static-export RSC compatibility (keep as you had)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/__next\.([^.\/]+)\.([^.\/]+)\.([^.\/]+)\.([^.\/]+)\.txt$ $1/__next.$2/$3/$4/$5.txt [L,NC]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/__next\.([^.\/]+)\.([^.\/]+)\.([^.\/]+)\.txt$ $1/__next.$2/$3/$4.txt [L,NC]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/__next\.([^.\/]+)\.([^.\/]+)\.txt$ $1/__next.$2/$3.txt [L,NC]

  # 5) Canonical product route redirects
  RewriteRule ^products/catalog/(.+)/?$ /products/$1/ [R=301,L,NC]
  RewriteRule ^km/products/catalog/(.+)/?$ /km/products/$1/ [R=301,L,NC]
  RewriteRule ^products/p10-outdoor-led-sign-board-price-in-bd/?$ /products/p10-outdoor-led-sign-board-price-in-cambodia/ [R=301,L,NC]

  RewriteRule ^products/led-display/?$ /led-display/ [R=301,L,NC]
  RewriteRule ^products/led-display/indoor-led-display/?$ /led-display/indoor-led-display/ [R=301,L,NC]
  RewriteRule ^products/led-display/outdoor-led-display/?$ /led-display/outdoor-led-display/ [R=301,L,NC]
  RewriteRule ^products/led-display/receiving-card/?$ /led-display/receiving-card/ [R=301,L,NC]
  RewriteRule ^products/led-display/video-processor/?$ /led-display/video-processor/ [R=301,L,NC]
  RewriteRule ^products/led-display/power-supply/?$ /led-display/power-supply/ [R=301,L,NC]
  RewriteRule ^products/indoor-led-display/?$ /led-display/indoor-led-display/ [R=301,L,NC]
  RewriteRule ^products/outdoor-led-display/?$ /led-display/outdoor-led-display/ [R=301,L,NC]
  RewriteRule ^products/led-controller/?$ /led-display/ [R=301,L,NC]
  RewriteRule ^products/interactive-flat-panel/?$ /interactive-flat-panel/ [R=301,L,NC]
  RewriteRule ^products/pa-system/?$ /pa-system/ [R=301,L,NC]
  RewriteRule ^products/turnstile-gate/?$ /turnstile-gate/ [R=301,L,NC]
  RewriteRule ^products/access-control-system/?$ /solutions/office-access-control-cambodia/ [R=301,L,NC]

  # 6) IMPORTANT: Fix sitemap-level duplicates (top-level -> /led-display/...)
  RewriteRule ^indoor-led-display/?$ /led-display/indoor-led-display/ [R=301,L,NC]
  RewriteRule ^outdoor-led-display/?$ /led-display/outdoor-led-display/ [R=301,L,NC]
  RewriteRule ^receiving-card/?$ /led-display/receiving-card/ [R=301,L,NC]
  RewriteRule ^video-processor/?$ /led-display/video-processor/ [R=301,L,NC]
  RewriteRule ^power-supply/?$ /led-display/power-supply/ [R=301,L,NC]

  # 7) Legacy solutions URL redirects
  RewriteRule ^solutions/led-billboard-cambodia/?$ /solutions/retail-digital-signage-cambodia/ [R=301,L,NC]
  RewriteRule ^solutions/digital-signage-cambodia/?$ /solutions/retail-digital-signage-cambodia/ [R=301,L,NC]
  RewriteRule ^solutions/pa-system-cambodia/?$ /solutions/factory-pa-announcement-cambodia/ [R=301,L,NC]
  RewriteRule ^solutions/smart-classroom-cambodia/?$ /solutions/education-smart-classroom-cambodia/ [R=301,L,NC]
  RewriteRule ^solutions/access-control-cambodia/?$ /solutions/office-access-control-cambodia/ [R=301,L,NC]
</IfModule>

<IfModule mod_headers.c>
  # Prevent stale HTML from referencing deleted hashed JS chunks after deploy.
  <FilesMatch "\.(html|htm)$">
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
  </FilesMatch>

  # Keep Next.js hashed static assets aggressively cached.
  SetEnvIfNoCase Request_URI "^/_next/static/" is_next_static=1
  Header always set Cache-Control "public, max-age=31536000, immutable" env=is_next_static

  # Cache media/static files for faster repeat visits without risking long stale HTML.
  SetEnvIfNoCase Request_URI "^/images/" is_image_asset=1
  Header always set Cache-Control "public, max-age=2592000" env=is_image_asset

  # Cache fonts strongly (typically fingerprinted/rarely changed).
  SetEnvIfNoCase Request_URI "\.(woff2?|ttf|otf|eot)$" is_font_asset=1
  Header always set Cache-Control "public, max-age=31536000, immutable" env=is_font_asset

  # Cache lightweight site assets.
  SetEnvIfNoCase Request_URI "^/(favicon\.ico|site\.webmanifest|manifest\.webmanifest)$" is_site_asset=1
  Header always set Cache-Control "public, max-age=604800" env=is_site_asset

  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<IfModule mod_brotli.c>
  BrotliCompressionQuality 5
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/javascript application/javascript application/json application/xml application/manifest+json image/svg+xml
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml application/manifest+json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType application/manifest+json "access plus 7 days"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/x-icon "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
</IfModule>

