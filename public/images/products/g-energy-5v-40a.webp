/* ==== Password Form Centering for LED Display Builder page ==== */

.post-password-form {
    max-width: 480px;
    margin: 80px auto !important; /* Center horizontally */
    text-align: center;
}

.post-password-form label {
    display: block;
    margin-bottom: 10px;
    font-size: 16px;
}

.post-password-form input[type="password"] {
    width: 70% !important;
    max-width: 260px;
    margin: 0 auto;
}

.post-password-form input[type="submit"] {
    padding: 10px 25px;
    margin-left: 10px;
}

.post-password-form input[type="password"],
.post-password-form input[type="submit"] {
    display: inline-block !important;
}
