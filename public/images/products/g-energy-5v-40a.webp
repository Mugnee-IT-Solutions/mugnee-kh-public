<!-- Floating Contact (FAB + Panel) — with SEO-safe hidden text -->
<script>
(function(){
  /* ====== CONTACTS ====== */
  var CALL      = "+8801711927445";
  var WA        = "8801711927445";
  var EMAIL     = "info@mugnee.com";
  var MESSENGER = "101287688070129";

  /* ====== CSS ====== */
  var css = `
  .mgn-contact{position:fixed;right:20px;bottom:110px;z-index:999999;font-family:system-ui,-apple-system,Segoe UI,Roboto,Ubuntu,Arial}
  .mgn-fab{
    width:60px;height:60px;border:0;cursor:pointer;position:relative;overflow:hidden;
    background:#10b981;border-radius:10px !important;box-shadow:0 6px 16px rgba(0,0,0,.25);
    display:inline-flex;align-items:center;justify-content:center;
  }
  .mgn-fab::after{content:"";position:absolute;inset:6px;background:#ffffff;border-radius:10px !important;z-index:0}
  .mgn-fab svg{width:30px;height:30px;position:absolute;inset:0;margin:auto;opacity:0;transform:scale(.7);transition:opacity .25s,transform .25s;z-index:1;pointer-events:none}
  .mgn-fab svg.active{opacity:1;transform:scale(1)}
  /* ✅ hidden but accessible text */
  .sr-only{
    position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;
    clip:rect(0,0,0,0);white-space:nowrap;border:0;z-index:-1;
  }

  .mgn-panel{width:250px;max-width:86vw;background:#fff;border-radius:16px;box-shadow:0 14px 34px rgba(0,0,0,.18);overflow:hidden;position:absolute;right:0;bottom:70px;transform:translateY(10px);opacity:0;pointer-events:none;transition:.22s}
  .mgn-panel.open{transform:translateY(0);opacity:1;pointer-events:auto}
  .mgn-head{background:#10b981;color:#fff;padding:12px 16px;font-weight:600;position:relative}
  .mgn-close{position:absolute;right:10px;top:10px;background:transparent;border:0;color:#fff;cursor:pointer;font-size:16px}
  .mgn-list{list-style:none;margin:0;padding:8px}
  .mgn-item{
    display:flex;align-items:center;gap:12px;padding:10px 12px;border-radius:8px;
    text-decoration:none !important;color:inherit;
  }
  .mgn-item:hover{background:#f6f8fb;text-decoration:none !important;}
  .mgn-ic{width:22px;height:22px;flex:0 0 22px}

  @media (max-width:600px){.mgn-contact{right:14px;bottom:160px !important}}
  `;
  var st=document.createElement('style');st.textContent=css;document.head.appendChild(st);

  /* ====== HTML ====== */
  var html = `
  <div class="mgn-contact" id="mgnContact">
    <div class="mgn-panel" id="mgnPanel" aria-hidden="true">
      <div class="mgn-head">Need help? Contact us!
        <button class="mgn-close" aria-label="Close" id="mgnClose">✕</button>
      </div>
      <ul class="mgn-list">
        <li><a class="mgn-item" href="https://m.me/${MESSENGER}" target="_blank" rel="noopener" aria-label="Chat on Messenger">
          <svg class="mgn-ic" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10" fill="#0084FF"/><path fill="#fff" d="M7 13.2l4.2-3.5 2.2 1.8 3.6-1.8-4.1 3.7-2.1-1.7z"/></svg>
          Messenger</a></li>
        <li><a class="mgn-item" href="https://wa.me/${WA}?text=Hello%20Mugnee%20Team" target="_blank" rel="noopener" aria-label="Chat on WhatsApp">
          <svg class="mgn-ic" viewBox="0 0 24 24" aria-hidden="true"><path fill="#25D366" d="M20.5 3.5A11 11 0 006.2 20.9L3 21l1-3.1A11 11 0 1020.5 3.5z"/><path fill="#fff" d="M16.9 13.9c-.2-.1-1.3-.6-1.5-.7-.2-.1-.4-.1-.6.1s-.7.7-.8.9c-.1.2-.3.2-.6.1-1.6-.6-2.7-1.5-3.6-3.1-.3-.5.3-.5.8-1.7.1-.2 0-.4 0-.5l-.7-1.7c-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.7.6-1 1.6-1 2.7s.9 2.4 1 2.6c.2.3 1.8 3 4.4 4.1.6.3 1.1.4 1.5.6.6.2 1.1.2 1.5.1.5-.1 1.3-.6 1.5-1.1.2-.5.2-1 .2-1.1 0-.1-.2-.2-.4-.3z"/></svg>
          WhatsApp</a></li>
        <li><a class="mgn-item" href="mailto:${EMAIL}" aria-label="Send us an email">
          <svg class="mgn-ic" viewBox="0 0 24 24" aria-hidden="true"><path fill="#EA4335" d="M12 13L2 6.5V18a2 2 0 002 2h16a2 2 0 002-2V6.5L12 13z"/><path fill="#FBBC04" d="M22 6l-10 7L2 6l10-4 10 4z"/></svg>
          Email</a></li>
        <li><a class="mgn-item" href="tel:${CALL}" aria-label="Call Mugnee Multiple Ltd.">
          <svg class="mgn-ic" viewBox="0 0 24 24" aria-hidden="true"><path fill="#10B981" d="M6.6 2h3l1 4-2 1.3a12.5 12.5 0 005.1 5.1L15 10l4 1v3a2 2 0 01-2.2 2 16.5 16.5 0 01-11.9-12A2 2 0 016.6 2z"/></svg>
          Direct call</a></li>
      </ul>
    </div>

    <!-- ✅ FAB with hidden text (anchor text) -->
    <button class="mgn-fab" id="mgnFab"
            aria-expanded="false"
            aria-label="Call Mugnee Multiple Ltd. – +8801711-927445">
      <span class="sr-only">Call Mugnee Multiple Ltd. – +8801711-927445</span>
      <!-- WhatsApp -->
      <svg viewBox="0 0 24 24" data-key="wa" aria-hidden="true"><path fill="#25D366" d="M20.5 3.5A11 11 0 006.2 20.9L3 21l1-3.1A11 11 0 1020.5 3.5z"/><path fill="#fff" d="M16.9 13.9c-.2-.1-1.3-.6-1.5-.7-.2-.1-.4-.1-.6.1s-.7.7-.8.9c-.1.2-.3.2-.6.1-1.6-.6-2.7-1.5-3.6-3.1-.3-.5.3-.5.8-1.7.1-.2 0-.4 0-.5l-.7-1.7c-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.7.6-1 1.6-1 2.7s.9 2.4 1 2.6c.2.3 1.8 3 4.4 4.1.6.3 1.1.4 1.5.6.6.2 1.1.2 1.5.1.5-.1 1.3-.6 1.5-1.1.2-.5.2-1 .2-1.1 0-.1-.2-.2-.4-.3z"/></svg>
      <!-- Call -->
      <svg viewBox="0 0 24 24" data-key="call" aria-hidden="true"><path fill="#10B981" d="M6.6 2h3l1 4-2 1.3a12.5 12.5 0 005.1 5.1L15 10l4 1v3a2 2 0 01-2.2 2 16.5 16.5 0 01-11.9-12A2 2 0 016.6 2z"/></svg>
      <!-- Email -->
      <svg viewBox="0 0 24 24" data-key="mail" aria-hidden="true"><path fill="#1F2937" d="M20 4H4a2 2 0 00-2 2v1.2l10 5.8 10-5.8V6a2 2 0 00-2-2z"/><path fill="#1F2937" d="M22 9.3l-10 5.8-10-5.8V18a2 2 0 002 2h16a2 2 0 002-2V9.3z"/></svg>
      <!-- Messenger -->
      <svg viewBox="0 0 24 24" data-key="msg" aria-hidden="true"><circle cx="12" cy="12" r="10" fill="#0084FF"/><path fill="#fff" d="M7 13.2l4.2-3.5 2.2 1.8 3.6-1.8-4.1 3.7-2.1-1.7z"/></svg>
      <!-- Close -->
      <svg viewBox="0 0 24 24" data-key="close" aria-hidden="true"><path fill="#ff3333" d="M18.3 5.7a1 1 0 0 0-1.4 0L12 10.6 7.1 5.7A1 1 0 1 0 5.7 7.1L10.6 12l-4.9 4.9a1 1 0 1 0 1.4 1.4L12 13.4l4.9 4.9a1 1 0 0 0 1.4-1.4L13.4 12l4.9-4.9a1 1 0 0 0 0-1.4z"/></svg>
    </button>
  </div>`;

  var wrap=document.createElement('div');wrap.innerHTML=html;document.body.appendChild(wrap);

  /* ====== JS (rotation + toggle) ====== */
  var fab=document.getElementById('mgnFab');
  var panel=document.getElementById('mgnPanel');
  var box=document.getElementById('mgnContact');
  var svgs=fab.querySelectorAll('svg');
  var order=['wa','call','mail','msg'];   // rotation order
  var idx=0, timer;

  function setActive(key){ svgs.forEach(s=>s.classList.toggle('active', s.getAttribute('data-key')===key)); }
  function startRotate(){ stopRotate(); setActive(order[idx%order.length]); timer=setInterval(function(){ idx++; setActive(order[idx%order.length]); },1800); }
  function stopRotate(){ if(timer){ clearInterval(timer); timer=null; } }

  setActive('wa'); startRotate();

  fab.addEventListener('click', function(){
    var open=panel.classList.toggle('open');
    fab.setAttribute('aria-expanded', open?'true':'false');
    if(open){ stopRotate(); setActive('close'); } else { startRotate(); }
  });
  document.getElementById('mgnClose').addEventListener('click',function(){
    panel.classList.remove('open'); fab.setAttribute('aria-expanded','false'); startRotate();
  });
  document.addEventListener('click',function(e){
    if(!box.contains(e.target)){ panel.classList.remove('open'); fab.setAttribute('aria-expanded','false'); startRotate(); }
  });
})();
</script>

</body>

</html>