<script type="text/javascript" id="jquery-js-after">
/* <![CDATA[ */
(function(){
  // make ids unique for all login forms except the first one
  function fixLoginFormIds(root){
    try{
      var scope = root && root.querySelectorAll ? root : document;
      var forms = scope.querySelectorAll('form.woocommerce-form-login');
      if(!forms || forms.length < 2) return;

      for (var i = 1; i < forms.length; i++){
        var f = forms[i];
        var suffix = '-dup' + i;
        ['username','password','rememberme','woocommerce-login-nonce'].forEach(function(id){
          var el = f.querySelector('#' + id);
          if (el) el.id = id + suffix;

          var lab = f.querySelector('label[for="' + id + '"]');
          if (lab) lab.setAttribute('for', id + suffix);
        });
      }
    }catch(e){}
  }

  // initial run
  document.addEventListener('DOMContentLoaded', function(){
    fixLoginFormIds(document);
  });

  // if header/off-canvas injects later, observe and fix on the fly
  var mo = new MutationObserver(function(muts){
    for (var k=0; k<muts.length; k++){
      var nodes = muts[k].addedNodes;
      for (var j=0; j<nodes.length; j++){
        var n = nodes[j];
        if (n.nodeType !== 1) continue;
        if (n.matches && n.matches('form.woocommerce-form-login, .woocommerce, .et-off-canvas, .account-dropdown')) {
          fixLoginFormIds(n);
        }
      }
    }
  });
  mo.observe(document.documentElement, {childList:true, subtree:true});
})();
//# sourceURL=jquery-js-after
/* ]]> */
